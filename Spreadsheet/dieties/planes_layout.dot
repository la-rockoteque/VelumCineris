graph planes {
  layout=neato;
  overlap=false;
  splines=true;
  node [shape=circle, style=filled, fillcolor="#f7f4ef", color="#333333", fontname="Helvetica"];

  orimond [label="Orimond", pos="0,0!", width=1.2, height=1.2];
  veil [label="The Veil", pos="0,0!", width=2.6, height=2.6, fillcolor="none"];

  %% Right stack (half-circle approximation by position)
  throne [label="The Throne\nof Ambitions", pos="2.6,1.2!", width=1.2, height=0.9];
  dreamscape [label="The Dreamscape", pos="2.6,0!", width=1.2, height=0.9];
  murmuring [label="The Murmuring\nDepths", pos="2.6,-1.2!", width=1.2, height=0.9];

  %% Left stack
  verdant [label="Verdant Cradle", pos="-2.6,1.2!", width=1.2, height=0.9];
  lithic [label="Lithic Bastion", pos="-2.6,0!", width=1.2, height=0.9];
  withered [label="Withered Womb", pos="-2.6,-1.2!", width=1.2, height=0.9];

  %% Back quadrant
  tesserac [label="Tesserac Leys", pos="0,2.6!", width=1.1, height=0.8];
  farcosmos [label="Far Cosmos", pos="1.6,2.6!", width=1.1, height=0.8];
  torment [label="Domain of\nTorment", pos="0,3.8!", width=1.1, height=0.8];
  loom [label="Infinite Loom", pos="1.6,3.8!", width=1.1, height=0.8];

  orimond -- veil [color="#666666"];
}
