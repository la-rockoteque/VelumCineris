# D&D Beyond Authentication Configuration
# Copy this file to .env and fill in your values
# Or use: poetry run python DNDBeyond/scripts/get_ddb_tokens.py

# D&D Beyond Base URL
DDB_BASE_URL="https://www.dndbeyond.com"

# Session Cookies (extracted from browser or via automation script)
DDB_COOKIES="CobaltSession=...; __cf_bm=...; ..."

# Security Tokens (from the homebrew creation form)
DDB_SECURITY_TOKEN="your-security-token-here"
DDB_AUTHENTICITY_TOKEN="your-authenticity-token-here"
REQUEST_VERIFICATION_TOKEN="your-verification-token-here"

# User Information
DDB_USER_ID="your-user-id"
DDB_USERNAME="your-username"

# Optional: Credentials for automated token extraction
# (Only needed if using get_ddb_tokens.py script)
# DDB_EMAIL="your-email@example.com"
# DDB_PASSWORD="your-password"

# Security Notes:
# - Never commit this file to git (it should be in .gitignore)
# - Tokens expire periodically and need to be refreshed
# - Treat these credentials like passwords
