{
  "name": "velum-studio-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_PATH=$PWD/node_modules vite --config vite.config.ts",
    "build": "NODE_PATH=$PWD/node_modules bun run typecheck && NODE_PATH=$PWD/node_modules vite build --config vite.config.ts",
    "preview": "NODE_PATH=$PWD/node_modules vite preview --config vite.config.ts",
    "typecheck": "NODE_PATH=$PWD/node_modules tsc --noEmit",
    "test": "NODE_PATH=$PWD/node_modules vitest run --config vitest.config.ts",
    "test:watch": "NODE_PATH=$PWD/node_modules vitest --config vitest.config.ts"
  },
  "dependencies": {
    "@velum/dsm": "file:../../../packages/velum-dsm",
    "@lottiefiles/dotlottie-web": "^0.52.0",
    "@tanstack/react-query": "^5.90.21",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "styletron-engine-atomic": "^1.6.2",
    "styletron-react": "^6.1.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.3.0",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react-swc": "^3.8.0",
    "happy-dom": "^20.7.0",
    "jsdom": "^27.0.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.1",
    "vitest": "^4.0.18"
  }
}
